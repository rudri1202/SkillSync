# ── Firebase (client-safe, must be prefixed with VITE_) ─────────────────────
# Get these from your Firebase project settings → General → Your apps → SDK setup
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Server-only secrets (DO NOT prefix with VITE_) ──────────────────────────
# GitHub Personal Access Token — needs 'repo' scope for collaborator invites
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Gemini API Key — get free tier key at: https://makersuite.google.com/app/apikey
# VITE_ prefix is required so Vite exposes it to the browser bundle
VITE_GEMINI_API_KEY=
GEMINI_API_KEY=   # kept for Vercel serverless functions (/api/gemini)
